{
    "extends": "astro/tsconfigs/strict",
    "exclude": [
        ".netlify",
        "dist",
        "node_modules",
        "tests"
    ],
    "compilerOptions": {
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@components/*": [
                "./src/components/*"
            ],
            "@content/*": [
                "./src/content/*"
            ],
            "@images/*": [
                "./src/images/*"
            ],
            "@lib/*": [
                "./src/lib/*"
            ],
            "@sections/*": [
                "./src/sections/*"
            ]
        },
        "types": [
            "bun-types"
        ]
    }
}