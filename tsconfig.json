{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@assets/*": [
                "src/assets/*"
            ],
            "@components/*": [
                "src/components/*"
            ],
            "@content/*": [
                "src/content/*"
            ],
            "@layouts/*": [
                "src/layouts/*"
            ],
            "@lib/*": [
                "src/lib/*"
            ],
            "@sections/*": [
                "src/sections/*"
            ]
        },
        "types": [
            "bun-types"
        ]
    },
    "exclude": [
        ".netlify",
        "dist",
        "node_modules"
    ]
}
